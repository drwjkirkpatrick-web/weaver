# .env.example — Environment variables for Weaver
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────

# Hardware mode: "real" (on Pi) or "mock" (development)
WEAVER_HARDWARE_MODE=mock

# Robot name
WEAVER_ROBOT_NAME=Weaver

# Log level: DEBUG, INFO, WARNING, ERROR
WEAVER_LOG_LEVEL=INFO

# ─── LLM Brain ───
# Mode: ollama_cloud or ollama_local
WEAVER_CORTEX_MODE=ollama_cloud

# Ollama Cloud settings (default mode — frees Pi RAM)
WEAVER_CORTEX_CLOUD_BASE_URL=https://api.ollama.cloud
WEAVER_CORTEX_CLOUD_MODEL=llama3.2:3b
WEAVER_CORTEX_CLOUD_API_KEY=your_ollama_cloud_api_key_here

# Ollama Local settings (fallback / swap mode)
WEAVER_CORTEX_LOCAL_BASE_URL=http://localhost:11434
WEAVER_CORTEX_LOCAL_MODEL=llama3.2:3b

# ─── Voice Pipeline ───
WEAVER_VOICE_STT_ENABLED=true
WEAVER_VOICE_STT_PROVIDER=local
WEAVER_VOICE_STT_MODEL=base
WEAVER_VOICE_TTS_ENABLED=true
WEAVER_VOICE_TTS_PROVIDER=edge
WEAVER_VOICE_TTS_VOICE=en-US-AriaNeural

# ─── Web Dashboard ───
WEAVER_WEB_HOST=0.0.0.0
WEAVER_WEB_PORT=8080

# ─── Safety ───
WEAVER_SAFETY_LEVEL=child

# ─── Camera ───
WEAVER_CAMERA_RESOLUTION_0=640
WEAVER_CAMERA_RESOLUTION_1=480
WEAVER_CAMERA_FRAMERATE=30

# ─── Battery (2S 18650 pack) ───
WEAVER_BATTERY_NOMINAL_VOLTAGE=7.4
WEAVER_BATTERY_FULL_VOLTAGE=8.4
WEAVER_BATTERY_EMPTY_VOLTAGE=6.0

# ─── Optional: Groq STT (faster than local) ───
# GROQ_API_KEY=your_groq_api_key

# ─── Optional: OpenAI TTS ───
# VOICE_TOOLS_OPENAI_KEY=your_openai_key